#version 460
#extension GL_EXT_scalar_block_layout : require
#extension GL_GOOGLE_include_directive : require

// DDGI probe update: gather this frame's ray results (ddgi_trace.comp) into the
// octahedral irradiance + depth atlases, blended with the previous frame
// (temporal hysteresis). Run twice (push.mode): 0 = irradiance (8x8 tiles),
// 1 = depth/moments (16x16 tiles). One invocation per atlas texel.

layout(local_size_x = 8, local_size_y = 8) in;

#include "ddgi.glsl"

layout(std140, set = 0, binding = 0) uniform DdgiUBO { DdgiParams ddgi; };
layout(std430, set = 0, binding = 1) readonly buffer RayRadiance { vec4 rayResult[]; };
layout(rgba16f, set = 0, binding = 2) uniform image2D irrAtlas; // .a = probe validity
layout(rg16f,   set = 0, binding = 3) uniform image2D depthAtlas;

layout(push_constant) uniform Push { int mode; } pc;

// Lower than the RTXGI default (50): with a modest ray count, a wide cone gives each
// depth texel coverage from several rays, so the mean reliably captures near occluders
// (thin walls) instead of latching onto one stray ray that missed the wall.
const float DEPTH_SHARPNESS = 8.0;

void main() {
    int res = (pc.mode == 0) ? DDGI_IRR_RES : DDGI_DEPTH_RES;
    ivec2 texel = ivec2(gl_GlobalInvocationID.xy);

    ivec2 tile  = texel / res;
    ivec2 local = texel - tile * res;
    // tile (tx,ty) -> probe (x,y,z): tx=x, ty = y + Ny*z.
    int nx = ddgi.gridCounts.x, ny = ddgi.gridCounts.y, nz = ddgi.gridCounts.z;
    if (tile.x >= nx || tile.y >= ny * nz) return;
    ivec3 c = ivec3(tile.x, tile.y % ny, tile.y / ny);
    if (c.z >= nz) return;
    int probe = ddgiProbeIndex(ddgi, c);

    vec3 texelDir = octDecode((vec2(local) + 0.5) / float(res));
    int rays = ddgi.gridCounts.w;

    float sumW = 0.0;
    vec3  accumColor = vec3(0.0);
    vec2  accumDepth = vec2(0.0); // mean, mean^2
    int   back = 0;               // backface ray count (over the full sphere), for classification
    for (int r = 0; r < rays; r++) {
        vec4 res4 = rayResult[probe * DDGI_MAX_RAYS + r];
        if (res4.a < 0.0) back++; // backface hit (trace stored a negative distance)
        vec3 rd = ddgiRayDir(ddgi, r);
        float d = dot(texelDir, rd);
        if (d <= 0.0) continue;
        if (pc.mode == 0) {
            accumColor += res4.rgb * d;
            sumW += d;
        } else {
            float w = pow(d, DEPTH_SHARPNESS);
            float dist = min(abs(res4.a), ddgi.shadowCfg.w); // |.| : backface dist is negative
            accumDepth += vec2(dist, dist * dist) * w;
            sumW += w;
        }
    }

    // Probe classification (RTXGI): a probe whose rays are mostly backfaces sits
    // inside/behind geometry -> INVALID. Stored in the irradiance atlas alpha (same for
    // every texel of the probe); the per-pixel lookup reads it and drops the probe.
    // This kills thin-wall leak with ZERO extra per-pixel rays.
    float valid = (float(back) / float(rays) > 0.25) ? 0.0 : 1.0;

    // Keep the previous value when no ray covered this texel's lobe this frame
    // (instead of resetting to 0 / maxDist, which would wreck the depth atlas -> leak).
    float hys = ddgi.params.x;
    if (pc.mode == 0) {
        vec3 prev = imageLoad(irrAtlas, texel).rgb;
        vec3 result = (sumW > 1e-6) ? accumColor / sumW : prev;
        imageStore(irrAtlas, texel, vec4(mix(result, prev, hys), valid)); // alpha = validity
    } else {
        vec2 prev = imageLoad(depthAtlas, texel).rg;
        vec2 result = (sumW > 1e-6) ? accumDepth / sumW : prev;
        imageStore(depthAtlas, texel, vec4(mix(result, prev, hys), 0.0, 0.0));
    }
}
