#version 460
#extension GL_EXT_nonuniform_qualifier : require
#extension GL_EXT_scalar_block_layout : require
#extension GL_GOOGLE_include_directive : require
#extension GL_EXT_ray_query : require

#include "pbr.glsl"

layout(local_size_x = 8, local_size_y = 8) in;

// ----- Scene set (set 0) -----
struct GpuMaterial {
    vec4  baseColorFactor;
    int   baseColorTexture;
    int   normalTexture;
    int   metalRoughTexture;
    int   occlusionTexture;
    float metallicFactor;
    float roughnessFactor;
    float occlusionStrength;
    float alphaCutoff;
    int   alphaMode;
    int   pad0;
    int   pad1;
    int   pad2;
};
struct Vertex { vec3 position; vec3 normal; vec2 uv; vec4 tangent; };
struct GpuInstance {
    mat4 transform;
    uint geometryID;
    uint pad0; uint pad1; uint pad2;
};
struct GpuGeometry {
    uint firstIndex;
    uint vertexOffset;
    uint materialIndex;
    uint pad;
};

layout(std430, set = 0, binding = 0) readonly buffer Materials { GpuMaterial materials[]; };
layout(set = 0, binding = 1) uniform sampler2D textures[];
layout(scalar, set = 0, binding = 2) readonly buffer Vertices { Vertex vertices[]; };
layout(std430, set = 0, binding = 3) readonly buffer Indices { uint indices[]; };
layout(scalar, set = 0, binding = 4) readonly buffer Instances { GpuInstance instances[]; };
layout(set = 0, binding = 5) uniform accelerationStructureEXT topLevelAS;
layout(std430, set = 0, binding = 6) readonly buffer Geometries { GpuGeometry geometries[]; };

// ----- Resolve set (set 1) -----
layout(r32ui, set = 1, binding = 0) uniform readonly uimage2D visImage;
layout(rgba16f, set = 1, binding = 1) uniform writeonly image2D hdrImage;
layout(set = 1, binding = 2) uniform sampler2D shadowHistRead;     // R=visibility, G=linear depth
layout(rg16f, set = 1, binding = 3) uniform writeonly image2D shadowHistWrite;
layout(rg16f, set = 1, binding = 4) uniform writeonly image2D motionImage; // prevUV - curUV (for DLSS)
// Ray Reconstruction guide buffers (always written; consumed only when RR active).
layout(rgba16f, set = 1, binding = 5) uniform writeonly image2D diffuseImage;  // diffuse albedo
layout(rgba16f, set = 1, binding = 6) uniform writeonly image2D specularImage; // specular F0
layout(rgba16f, set = 1, binding = 7) uniform writeonly image2D normalImage;   // xyz=world N, w=roughness
// Deferred shadow split (SVGF): direct sun radiance WITHOUT shadow, + shadow scalar.
// The composite pass recombines: hdr = ambient + directLight * shadow(filtered).
layout(rgba16f, set = 1, binding = 8) uniform writeonly image2D directLightImage;
layout(r16f,    set = 1, binding = 9) uniform writeonly image2D shadowOutImage;

layout(push_constant) uniform Push {
    mat4  viewProj;
    mat4  prevViewProj;  // temporal reprojection of the shadow history
    vec4  cameraPos;
    vec4  sunDir;        // xyz = dir to sun, w = ambient
    vec4  sunColor;      // rgb = radiance
    vec4  shadowCfg;     // x=sunConeRad y=samples z=shadowsOn w=frameIndex
    vec4  temporal;      // x=reset y=histAlpha z=denoiseOn
    vec4  jitter;        // xy = current jitter in NDC, z = debugMotion flag
    uvec2 screenSize;
} pc;

#include "rtshadow.glsl"

// Procedural sky (no RT): horizon->zenith gradient + an HDR sun disk in the sun
// direction, so the window shows the background and the sun's actual position.
vec3 skyColor(vec3 dir, vec3 L) {
    float h  = clamp(dir.y, -1.0, 1.0);
    float up = max(h, 0.0);
    vec3 zenith = vec3(0.10, 0.28, 0.65);
    vec3 ground = vec3(0.16, 0.30, 0.15); // natural green
    // Direct sky->ground transition with a tiny smooth across the horizon.
    vec3 col = mix(ground, zenith, smoothstep(-0.01, 0.01, h));
    // Warm band along the horizon toward the sun's azimuth (sunrise/sunset feel).
    float azAlign = max(dot(normalize(vec3(dir.x, 0.0, dir.z)),
                            normalize(vec3(L.x, 0.0, L.z))), 0.0);
    col += vec3(0.45, 0.22, 0.08) * pow(azAlign, 4.0) * pow(1.0 - up, 6.0);

    // Sun: bright HDR core + halo (warm), positioned at L.
    float cosA = dot(dir, L);
    float ang  = acos(clamp(cosA, -1.0, 1.0));
    float disk = 1.0 - smoothstep(0.009, 0.013, ang);     // ~0.6 deg core, soft edge
    float halo = exp(-ang * ang / (2.0 * 0.05 * 0.05)) * 0.6 // tight glow
               + pow(max(cosA, 0.0), 8.0) * 0.12;            // broad glow
    col += vec3(1.0, 0.96, 0.88) * disk * 40.0;
    col += vec3(1.0, 0.85, 0.60) * halo;
    return col;
}

float cross2(vec2 a, vec2 b) { return a.x * b.y - a.y * b.x; }

// Perspective-correct UV at NDC point p (for analytic texture gradients).
vec2 perspUV(vec2 p, vec2 s0, vec2 s1, vec2 s2, vec3 invW, float area,
             vec2 uv0, vec2 uv1, vec2 uv2) {
    vec3 l = vec3(cross2(s1 - p, s2 - p),
                  cross2(s2 - p, s0 - p),
                  cross2(s0 - p, s1 - p)) / area;
    vec3 pw = l * invW;
    pw /= (pw.x + pw.y + pw.z);
    return uv0 * pw.x + uv1 * pw.y + uv2 * pw.z;
}

void main() {
    ivec2 pix = ivec2(gl_GlobalInvocationID.xy);
    if (pix.x >= int(pc.screenSize.x) || pix.y >= int(pc.screenSize.y)) return;

    uint v = imageLoad(visImage, pix).r;
    if (v == 0xFFFFFFFFu) {
        // Empty pixel: reconstruct the world view ray and draw the procedural sky.
        vec2 suv = (vec2(pix) + 0.5) / vec2(pc.screenSize);
        vec4 farP = inverse(pc.viewProj) * vec4(suv * 2.0 - 1.0, 1.0, 1.0);
        vec3 rayDir = normalize(farP.xyz / farP.w - pc.cameraPos.xyz);
        vec3 sky = skyColor(rayDir, normalize(pc.sunDir.xyz));
        imageStore(hdrImage, pix, vec4(sky, 1.0));
        imageStore(shadowHistWrite, pix, vec4(1.0, 1e6, 0.0, 0.0)); // lit + far depth
        imageStore(motionImage, pix, vec4(0.0));                    // sky: no motion
        imageStore(diffuseImage, pix, vec4(0.0));                   // RR guides: empty
        imageStore(specularImage, pix, vec4(0.0));
        imageStore(normalImage, pix, vec4(0.0, 0.0, 0.0, 1.0));
        imageStore(directLightImage, pix, vec4(0.0));               // composite: ambient(sky)+0
        imageStore(shadowOutImage, pix, vec4(1.0));
        if (pc.jitter.z > 0.5) imageStore(hdrImage, pix, vec4(0.5, 0.5, 0.0, 1.0));
        return;
    }

    uint instID = v >> 20;
    uint primID = v & 0xFFFFFu;
    GpuInstance inst = instances[instID];
    GpuGeometry d = geometries[inst.geometryID];
    mat4 model = inst.transform;

    uint base = d.firstIndex + primID * 3u;
    uint i0 = indices[base + 0u] + d.vertexOffset;
    uint i1 = indices[base + 1u] + d.vertexOffset;
    uint i2 = indices[base + 2u] + d.vertexOffset;
    Vertex a0 = vertices[i0];
    Vertex a1 = vertices[i1];
    Vertex a2 = vertices[i2];

    // World + clip positions.
    vec3 wp0 = (model * vec4(a0.position, 1.0)).xyz;
    vec3 wp1 = (model * vec4(a1.position, 1.0)).xyz;
    vec3 wp2 = (model * vec4(a2.position, 1.0)).xyz;
    vec4 c0 = pc.viewProj * vec4(wp0, 1.0);
    vec4 c1 = pc.viewProj * vec4(wp1, 1.0);
    vec4 c2 = pc.viewProj * vec4(wp2, 1.0);
    vec3 n0 = c0.xyz / c0.w;
    vec3 n1 = c1.xyz / c1.w;
    vec3 n2 = c2.xyz / c2.w;

    // Pixel NDC (same convention the vis pass rasterized with).
    vec2 uv = (vec2(pix) + 0.5) / vec2(pc.screenSize);
    vec2 p = uv * 2.0 - 1.0;

    // 2D barycentric, then perspective-correct using 1/w.
    float area = cross2(n1.xy - n0.xy, n2.xy - n0.xy);
    float l0 = cross2(n1.xy - p, n2.xy - p) / area;
    float l1 = cross2(n2.xy - p, n0.xy - p) / area;
    float l2 = cross2(n0.xy - p, n1.xy - p) / area;
    vec3 pw = vec3(l0 / c0.w, l1 / c1.w, l2 / c2.w);
    pw /= (pw.x + pw.y + pw.z);

    vec3 worldPos = wp0 * pw.x + wp1 * pw.y + wp2 * pw.z;
    mat3 nm = transpose(inverse(mat3(model)));
    vec3 N = normalize(nm * (a0.normal * pw.x + a1.normal * pw.y + a2.normal * pw.z));
    vec2 tuv = a0.uv * pw.x + a1.uv * pw.y + a2.uv * pw.z;

    // Two-sided: face the GEOMETRIC normal toward the viewer BEFORE normal mapping.
    // (Flipping the perturbed normal afterwards mirrors detail and causes
    //  camera-dependent dark patches.) faceSign also fixes the bitangent.
    vec3 V = normalize(pc.cameraPos.xyz - worldPos);
    float faceSign = (dot(N, V) < 0.0) ? -1.0 : 1.0;
    N *= faceSign;

    // Analytic UV gradients (no quad derivatives in compute) → mip selection.
    vec3 invW = vec3(1.0 / c0.w, 1.0 / c1.w, 1.0 / c2.w);
    vec2 tuvX = perspUV(p + vec2(2.0 / float(pc.screenSize.x), 0.0),
                        n0.xy, n1.xy, n2.xy, invW, area, a0.uv, a1.uv, a2.uv);
    vec2 tuvY = perspUV(p + vec2(0.0, 2.0 / float(pc.screenSize.y)),
                        n0.xy, n1.xy, n2.xy, invW, area, a0.uv, a1.uv, a2.uv);
    vec2 dUVdx = tuvX - tuv;
    vec2 dUVdy = tuvY - tuv;

    // Interpolated tangent (glTF vertex tangent; .w = handedness).
    vec4 tan4 = a0.tangent * pw.x + a1.tangent * pw.y + a2.tangent * pw.z;
    vec3 T = normalize(mat3(model) * tan4.xyz);

    // Material.
    GpuMaterial m = materials[d.materialIndex];
    vec3 albedo = m.baseColorFactor.rgb;
    if (m.baseColorTexture >= 0)
        albedo *= textureGrad(textures[nonuniformEXT(m.baseColorTexture)], tuv, dUVdx, dUVdy).rgb;
    float metallic  = m.metallicFactor;
    float roughness = m.roughnessFactor;
    if (m.metalRoughTexture >= 0) {
        vec4 mr = textureGrad(textures[nonuniformEXT(m.metalRoughTexture)], tuv, dUVdx, dUVdy);
        roughness *= mr.g; // glTF: G = roughness
        metallic  *= mr.b; // glTF: B = metallic
    }
    roughness = clamp(roughness, 0.04, 1.0);

    // Baked ambient occlusion (glTF occlusion: R channel). Reuse the metalRough
    // fetch when the occlusion map is the same packed ORM image.
    float ao = 1.0;
    if (m.occlusionTexture >= 0) {
        float occ = (m.occlusionTexture == m.metalRoughTexture)
            ? textureGrad(textures[nonuniformEXT(m.metalRoughTexture)], tuv, dUVdx, dUVdy).r
            : textureGrad(textures[nonuniformEXT(m.occlusionTexture)],  tuv, dUVdx, dUVdy).r;
        ao = mix(1.0, occ, m.occlusionStrength);
    }

    // Tangent-space normal mapping. Gram-Schmidt re-orthonormalize against N.
    if (m.normalTexture >= 0) {
        T = normalize(T - N * dot(N, T));
        vec3 B = cross(N, T) * tan4.w * faceSign;
        vec3 nt = textureGrad(textures[nonuniformEXT(m.normalTexture)], tuv, dUVdx, dUVdy).xyz * 2.0 - 1.0;
        N = normalize(mat3(T, B, N) * nt);
    }

    vec3 L = normalize(pc.sunDir.xyz);

    float shadow = 1.0;
    if (pc.shadowCfg.z > 0.5)
        shadow = traceSunShadow(worldPos, N, L, pc.shadowCfg.x,
                                int(pc.shadowCfg.y), uint(pc.shadowCfg.w), vec2(pix));

    // ----- Temporal accumulation (reproject last frame's shadow) -----
    float curW = (pc.viewProj * vec4(worldPos, 1.0)).w; // linear depth proxy (clip w)
    {
        vec4 pc4 = pc.prevViewProj * vec4(worldPos, 1.0);
        if (pc.temporal.z > 0.5 && pc.temporal.x < 0.5 && pc4.w > 0.0) {
            vec2 pv = (pc4.xy / pc4.w) * 0.5 + 0.5;
            if (all(greaterThanEqual(pv, vec2(0.0))) && all(lessThanEqual(pv, vec2(1.0)))) {
                vec2 hist = texture(shadowHistRead, pv).rg; // r=shadow, g=depth
                // Accept if the reprojected surface depth matches (same surface).
                if (abs(hist.g - pc4.w) <= 0.03 * pc4.w)
                    shadow = mix(hist.r, shadow, pc.temporal.y);
            }
        }
    }
    imageStore(shadowHistWrite, pix, vec4(shadow, curW, 0.0, 0.0));

    // ----- Motion vectors (Current - Prev). Static scene -> camera-only. -----
    // DLSS expects motion vectors to point from previous to current (Current - Prev).
    vec2 motion = vec2(0.0);
    {
        vec4 pp = pc.prevViewProj * vec4(worldPos, 1.0);
        if (pp.w > 0.0) {
            vec2 prevUV = (pp.xy / pp.w) * 0.5 + 0.5;
            vec2 curUnjitUV = uv - (pc.jitter.xy * 0.5);
            motion = curUnjitUV - prevUV;
        }
    }
    imageStore(motionImage, pix, vec4(motion, 0.0, 0.0));

    // ----- Ray Reconstruction guide buffers -----
    // Diffuse albedo (energy that goes to the Lambert term) and specular F0
    // (dielectric 0.04, metals tint by albedo). World-space N + packed roughness.
    vec3 diffuseAlbedo  = albedo * (1.0 - metallic);
    vec3 specularAlbedo = mix(vec3(0.04), albedo, metallic);
    imageStore(diffuseImage,  pix, vec4(diffuseAlbedo, 1.0));
    imageStore(specularImage, pix, vec4(specularAlbedo, 1.0));
    imageStore(normalImage,   pix, vec4(N, roughness));

    // ----- Deferred shadow split -----
    // Direct sun term WITHOUT shadow (composite multiplies the denoised shadow back in)
    // and ambient (shadow-independent) straight into HDR.
    vec3 direct  = cookTorrance(N, V, L, albedo, metallic, roughness, pc.sunColor.rgb);
    vec3 ambient = pc.sunDir.w * albedo * ao; // occluded by baked AO (real GI in Faz 7)
    imageStore(directLightImage, pix, vec4(direct, curW)); // .a = linear depth for à-trous edge-stop
    imageStore(shadowOutImage,   pix, vec4(shadow));
    imageStore(hdrImage,         pix, vec4(ambient, 1.0));

    if (pc.jitter.z > 0.5)             // debug: visualize motion (composite skipped on CPU)
        imageStore(hdrImage, pix, vec4(motion * 20.0 + 0.5, 0.5, 1.0));
}
